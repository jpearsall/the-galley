{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/galley.schema.json",
  "title": "Galley data file",
  "type": "object",
  "required": ["schemaVersion", "updated", "targets", "days", "catalog", "meals", "batch", "rotation", "plan", "shop"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "targets": {
      "type": "object",
      "required": ["calLo", "calHi", "pLo", "pHi"],
      "additionalProperties": false,
      "properties": {
        "calLo": { "type": "integer", "minimum": 1000, "maximum": 6000 },
        "calHi": { "type": "integer", "minimum": 1000, "maximum": 6000 },
        "pLo": { "type": "integer", "minimum": 0, "maximum": 400 },
        "pHi": { "type": "integer", "minimum": 0, "maximum": 400 }
      }
    },
    "days": {
      "type": "array", "minItems": 7, "maxItems": 7,
      "items": { "type": "string" }
    },
    "catalog": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["brand", "nm", "note", "q"],
        "additionalProperties": false,
        "properties": {
          "brand": { "type": "string" },
          "nm": { "type": "string", "minLength": 1 },
          "note": { "type": "string" },
          "q": { "type": "string", "minLength": 1 },
          "cal": { "type": "integer", "minimum": 0, "maximum": 2000 },
          "p": { "type": "integer", "minimum": 0, "maximum": 200 },
          "c": { "type": "integer", "minimum": 0, "maximum": 300 },
          "f": { "type": "integer", "minimum": 0, "maximum": 200 },
          "planDesc": { "type": "string" }
        }
      }
    },
    "meals": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["slot", "nm", "appliance", "active", "desc", "cal", "p", "c", "f"],
        "additionalProperties": false,
        "properties": {
          "slot": { "enum": ["Breakfast", "Lunch", "Dinner", "Snack"] },
          "nm": { "type": "string", "minLength": 1 },
          "appliance": { "type": "string" },
          "active": { "type": "integer", "minimum": 0, "maximum": 60 },
          "desc": { "type": "string" },
          "cal": { "type": "integer", "minimum": 0, "maximum": 2000 },
          "p": { "type": "integer", "minimum": 0, "maximum": 200 },
          "c": { "type": "integer", "minimum": 0, "maximum": 300 },
          "f": { "type": "integer", "minimum": 0, "maximum": 200 }
        }
      }
    },
    "batch": {
      "type": "object",
      "required": ["A", "B"],
      "additionalProperties": false,
      "properties": {
        "A": { "$ref": "#/$defs/batchWeek" },
        "B": { "$ref": "#/$defs/batchWeek" }
      }
    },
    "rotation": {
      "type": "array", "minItems": 4, "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["entrees", "snacks"],
        "additionalProperties": false,
        "properties": {
          "entrees": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "snacks": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "plan": {
      "type": "object",
      "required": ["A", "B"],
      "additionalProperties": false,
      "properties": {
        "A": { "$ref": "#/$defs/planWeek" },
        "B": { "$ref": "#/$defs/planWeek" }
      }
    },
    "shop": {
      "type": "object",
      "required": ["A", "B"],
      "additionalProperties": false,
      "properties": {
        "A": { "$ref": "#/$defs/shopWeek" },
        "B": { "$ref": "#/$defs/shopWeek" }
      }
    }
  },
  "$defs": {
    "batchWeek": {
      "type": "object",
      "required": ["active", "steps"],
      "additionalProperties": false,
      "properties": {
        "active": { "type": "string" },
        "steps": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "array", "minItems": 2, "maxItems": 2,
            "items": { "type": "string" }
          }
        }
      }
    },
    "planWeek": {
      "type": "array", "minItems": 7, "maxItems": 7,
      "items": {
        "type": "array", "minItems": 5, "maxItems": 5,
        "items": { "type": "string" }
      }
    },
    "shopWeek": {
      "type": "object",
      "required": ["cats"],
      "additionalProperties": false,
      "properties": {
        "cats": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "ico", "items"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "ico": { "type": "string" },
              "items": {
                "type": "array", "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "nm": { "type": "string" },
                    "qty": { "type": "string" },
                    "q": { "type": "string" },
                    "ref": { "type": "string" }
                  },
                  "anyOf": [
                    { "required": ["ref", "qty"] },
                    { "required": ["nm", "qty", "q"] }
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
